# Required — Claude API key for the pipeline
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Automation settings (all have safe defaults)
DRY_RUN=true                          # Set to "false" to enable real sends
POLL_INTERVAL_MS=60000                # Gmail poll interval (default 60s)
EDGE_CASE_BUDGET_THRESHOLD=3000       # Hold leads above this quote price

# Gmail API (run: npx tsx scripts/gmail-auth.ts)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=data/gmail-token.json

# Twilio SMS (for edge case notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Portal credentials (for Playwright auto-reply)
GIGSALAD_EMAIL=
GIGSALAD_PASSWORD=
YELP_EMAIL=
YELP_PASSWORD=

# Logging
LOG_PATH=logs/leads.jsonl
