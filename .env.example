# --- Required API Keys ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Twilio (SMS notifications) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
ALEX_PHONE=+1234567890

# --- Mailgun (inbound email webhook) ---
MAILGUN_WEBHOOK_KEY=your-mailgun-webhook-signing-key

# --- Database ---
# Local dev: ./data/leads.db
# Railway: /data/leads.db (must match volume mount path)
DATABASE_PATH=./data/leads.db

# --- Server ---
# Railway sets PORT automatically; locally defaults to 3000
PORT=3000
# Must match your Railway public URL exactly (including https://)
# Used for Twilio signature validation and dashboard links in SMS
BASE_URL=https://your-app.up.railway.app

# --- Dashboard (Basic Auth) ---
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me

# --- Twilio Validation Escape Hatch ---
# Set to "true" TEMPORARILY to debug Twilio webhook URL mismatches.
# Twilio signature validation compares BASE_URL against the request.
# If BASE_URL doesn't match your Railway domain exactly, all webhooks
# fail with 401. Set this to true, check logs, fix BASE_URL, then
# set back to false immediately.
DISABLE_TWILIO_VALIDATION=false

# --- Mailgun Validation Escape Hatch ---
# Set to "true" TEMPORARILY to debug Mailgun webhook 401 errors.
# Mailgun has multiple keys (API key, domain key, webhook signing key).
# The webhook signing key is under Mailgun → Settings → Webhooks, NOT
# under API Keys. If you copy the wrong key, all inbound emails silently
# fail with 401. Set this to true, confirm webhooks arrive, find the
# correct signing key, then set back to false immediately.
DISABLE_MAILGUN_VALIDATION=false
